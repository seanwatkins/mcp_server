# OctopusBaby MCP Server - Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# -----------------------------------------------------------
# MCP Server
# -----------------------------------------------------------
# Public URL where Claude.ai will reach this server
# e.g. https://your-server.example.com
MCP_SERVER_URL=https://your-cloudflare-tunnel-url.example.com

# Port the server listens on inside the container (default: 8765)
MCP_PORT=8765

# -----------------------------------------------------------
# Cloudflare Tunnel (optional)
# -----------------------------------------------------------
# Token from Cloudflare Zero Trust -> Tunnels -> your tunnel
TUNNEL_TOKEN=

# -----------------------------------------------------------
# MQTT Logging (optional)
# -----------------------------------------------------------
# IP/hostname of your MQTT broker
MQTT_HOST=127.0.0.1
MQTT_PORT=1883
MQTT_TOPIC=mcp-server/log
MQTT_STATUS_TOPIC=mcp-server/status

# -----------------------------------------------------------
# Grafana (optional - only needed for the grafana tool)
# -----------------------------------------------------------
GRAFANA_URL=http://your-grafana:3000
GRAFANA_USER=admin
GRAFANA_PASS=your-grafana-password
